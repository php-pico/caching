{
    "name"        : "php-pico/caching",
    "description" : "A PSR-6/PSR-16 compliant caching package.",
    "type"        : "library",
    "license"     : "MIT",
    "minimum-stability": "stable",
    "scripts"     : {
        "format": "mago format",
        "mago": "mago analyze",
        "test": "phpunit -c phpunit.xml.dist",
        "qa": [
            "@format",
            "@mago",
            "@test"
        ]
    },
    "require"     : {
        "php": "^8.5",
        "psr/simple-cache": "^3.0",
        "psr/cache": "^3.0"
    },
    "autoload"    : {
        "psr-4": {
            "PhpPico\\Caching\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpPico\\Caching\\Tests\\": "tests/"
        }
    },
    "require-dev" : {
        "carthage-software/mago": "^1.30.0",
        "phpunit/phpunit": "^12.5.30"
    },
    "config"      : {
        "allow-plugins": {
            "carthage-software/mago": true
        }
    }
}
